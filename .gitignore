# CodeIgniter 4 .gitignore
# https://github.com/bcit-ci/CodeIgniter4

# Project ENVIROMENT
.env
.env.local
.env.*.local

# Folder Uploads
public/uploads/*
!public/uploads/.gitkeep

# Writable directory
writable/cache/*
!writable/cache/.gitkeep
writable/logs/*
!writable/logs/.gitkeep
writable/session/*
!writable/session/.gitkeep
writable/uploads/*
!writable/uploads/.gitkeep
writable/debugbar/*
!writable/debugbar/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Python virtual environment (if using local Flask)
python_api/venv/

# Python bytecode cache
__pycache__/
*.py[cod]

# Model cache files
*.pkl
*.joblib
!python_api/harvest_model.joblib

# Node modules
node_modules/
