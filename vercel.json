{
  "version": 2,
  "builds": [
    {
      "src": "lettuce/public/index.php",
      "use": "@vercel/php"
    }
  ],
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python"
    },
    "public/index.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/lettuce/public/index.php"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/lettuce/public/index.php"
    }
  ]
}
